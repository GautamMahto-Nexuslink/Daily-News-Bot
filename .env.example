# --- Telegram (recommended) ---
# 1. Message @BotFather on Telegram -> /newbot -> get BOT_TOKEN
# 2. Start a chat with your bot, then visit:
#    https://api.telegram.org/bot<BOT_TOKEN>/getUpdates
#    to find your CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email (optional, alternative to Telegram) ---
# For Gmail: enable "App Passwords" in Google Account -> Security
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECIPIENT=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# --- Ollama (optional local LLM summarization) ---
# Install: https://ollama.com
# Check available models: curl http://localhost:11434/api/tags
# Set OLLAMA_MODEL to any model you have pulled (e.g. qwen2.5vl:3b, llama3, mistral)
OLLAMA_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:3b

# --- Digest settings ---
TOP_N_ARTICLES=10
MAX_SUMMARY_WORDS=60
LOOKBACK_HOURS=24
